{
  "name": "Quantum Fluidity",
  "type": "dark",
  "semanticHighlighting": true,
  "semanticTokenColors": {
    "class": {
      "foreground": "#00E676",
      "bold": true
    },
    "interface": {
      "foreground": "#FFB800",
      "italic": true
    },
    "function": {
      "foreground": "#00D1FF",
      "italic": true
    },
    "method": {
      "foreground": "#00D1FF",
      "italic": true
    },
    "variable.readonly": {
      "foreground": "#F8F9FA",
      "bold": true
    },
    "variable.defaultLibrary": {
      "foreground": "#00D1FF",
      "bold": true
    },
    "property": {
      "foreground": "#F8F9FA"
    },
    "parameter": {
      "foreground": "#00D1FF",
      "italic": true
    },
    "enum": {
      "foreground": "#00E676",
      "bold": true
    },
    "enumMember": {
      "foreground": "#FFB800"
    },
    "type": {
      "foreground": "#00E676"
    },
    "typeParameter": {
      "foreground": "#00E676",
      "italic": true
    },
    "struct": {
      "foreground": "#00E676",
      "bold": true
    },
    "namespace": {
      "foreground": "#F8F9FA"
    },
    "decorator": {
      "foreground": "#00D1FF",
      "italic": true
    },
    "macro": {
      "foreground": "#B266FF"
    },
    "event": {
      "foreground": "#FFB800"
    },
    "property.readonly": {
      "foreground": "#F8F9FA",
      "bold": true
    },
    "*.deprecated": {
      "strikethrough": true
    }
  },
