    "activityBar.border": "#1A1A2E",
    "sideBar.background": "#050505",
    "sideBar.foreground": "#F8F9FA",
    "sideBar.border": "#1A1A2E",
    "sideBarSectionHeader.background": "#0a0a0a",
    "sideBarSectionHeader.foreground": "#F8F9FA",
    "terminal.background": "#050505",
