    "terminal.ansiWhite": "#F8F9FA",
    "terminal.ansiBrightBlack": "#1A1A2E",
    "terminal.ansiBrightRed": "#FF3377",
    "terminal.ansiBrightGreen": "#33FFAA",
    "terminal.ansiBrightYellow": "#FFD133",
    "terminal.ansiBrightBlue": "#33DDFF",
    "terminal.ansiBrightMagenta": "#C888FF",
    "terminal.ansiBrightCyan": "#33DDFF",
    "terminal.ansiBrightWhite": "#FFFFFF",
    "editor.selectionBackground": "#1A1A2E",
    "editor.selectionHighlightBackground": "#1A1A2E80",
    "editor.wordHighlightBackground": "#1A1A2E80",
    "editor.lineHighlightBackground": "#0a0a0a",
    "editorLineNumber.foreground": "#F8F9FA40",
    "editorLineNumber.activeForeground": "#00D1FF",
    "editorCursor.foreground": "#00D1FF",
    "editorIndentGuide.background": "#1A1A2E80",
    "editorIndentGuide.activeBackground": "#1A1A2E",
    "list.activeSelectionBackground": "#1A1A2E",
    "list.activeSelectionForeground": "#F8F9FA",
    "list.inactiveSelectionBackground": "#1A1A2E80",
    "list.inactiveSelectionForeground": "#F8F9FA",
    "list.hoverBackground": "#0a0a0a",
    "list.hoverForeground": "#F8F9FA",
    "list.focusBackground": "#1A1A2E",
    "list.focusForeground": "#00D1FF",
    "list.highlightForeground": "#00D1FF",
    "focusBorder": "#00D1FF",
    "badge.background": "#B266FF",
    "badge.foreground": "#050505",
    "panel.background": "#050505",
    "panel.border": "#1A1A2E",
    "panelTitle.activeBorder": "#00D1FF",
    "panelTitle.activeForeground": "#F8F9FA",
    "panelTitle.inactiveForeground": "#F8F9FA80",
    "tab.activeBackground": "#050505",
    "tab.activeForeground": "#F8F9FA",
    "tab.activeBorder": "#00D1FF",
    "tab.inactiveBackground": "#0a0a0a",
    "tab.inactiveForeground": "#F8F9FA80",
    "tab.border": "#1A1A2E",
    "editorGroupHeader.tabsBackground": "#050505",
    "editorGroup.border": "#1A1A2E",
    "titleBar.activeBackground": "#050505",
    "titleBar.activeForeground": "#F8F9FA",
    "titleBar.inactiveBackground": "#050505",
    "titleBar.inactiveForeground": "#F8F9FA80",
    "statusBar.background": "#1A1A2E",
    "statusBar.foreground": "#F8F9FA",
    "statusBar.border": "#1A1A2E",
    "statusBar.debuggingBackground": "#B266FF",
    "statusBar.debuggingForeground": "#050505",
    "statusBar.noFolderBackground": "#050505",
    "button.background": "#B266FF",
    "button.foreground": "#050505",
    "button.hoverBackground": "#C888FF",
    "button.secondaryBackground": "#1A1A2E",
    "button.secondaryForeground": "#F8F9FA",
    "button.secondaryHoverBackground": "#2A2A4E",
    "input.background": "#0a0a0a",
    "input.foreground": "#F8F9FA",
    "input.border": "#1A1A2E",
    "inputOption.activeBorder": "#00D1FF",
    "inputValidation.errorBackground": "#FF005540",
    "inputValidation.errorBorder": "#FF0055",
    "dropdown.background": "#0a0a0a",
    "dropdown.foreground": "#F8F9FA",
    "dropdown.border": "#1A1A2E",
    "editorWidget.background": "#0a0a0a",
    "editorWidget.border": "#1A1A2E",
    "editorSuggestWidget.background": "#0a0a0a",
    "editorSuggestWidget.border": "#1A1A2E",
    "editorSuggestWidget.selectedBackground": "#1A1A2E",
    "diffEditor.insertedTextBackground": "#00E67620",
    "diffEditor.removedTextBackground": "#FF005520",
    "editorGutter.addedBackground": "#00E676",
    "editorGutter.modifiedBackground": "#00D1FF",
    "editorGutter.deletedBackground": "#FF0055",
    "scrollbarSlider.background": "#1A1A2E80",
    "scrollbarSlider.hoverBackground": "#1A1A2E",
    "scrollbarSlider.activeBackground": "#00D1FF80",
    "scrollbar.shadow": "#050505"
  },
  "tokenColors": [
    {
      "name": "Comment",
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "fontStyle": "italic",
        "foreground": "#F8F9FA66"
      }
    },
    {
      "name": "Variables",
      "scope": [
        "variable",
        "string constant.other.placeholder"
      ],
      "settings": {
        "foreground": "#F8F9FA"
      }
    },
    {
      "name": "Colors",
      "scope": [
        "constant.other.color"
      ],
      "settings": {
        "foreground": "#00D1FF"
      }
    },
    {
      "name": "Invalid",
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "settings": {
        "foreground": "#B266FF"
      }
    },
    {
      "name": "Keyword, Storage",
      "scope": [
        "keyword",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#B266FF"
      }
    },
    {
      "name": "Operator, Misc",
      "scope": [
        "keyword.control",
        "constant.other.color",
        "punctuation",
        "meta.tag",
        "punctuation.definition.tag",
        "punctuation.separator.inheritance.php",
        "punctuation.definition.tag.html",
        "punctuation.definition.tag.begin.html",
        "punctuation.definition.tag.end.html",
        "punctuation.section.embedded",
        "keyword.other.template",
        "keyword.other.substitution"
      ],
      "settings": {
        "foreground": "#B266FF"
      }
    },
    {
      "name": "Tag",
      "scope": [
        "entity.name.tag",
        "meta.tag.sgml",
        "markup.deleted.git_gutter"
      ],
      "settings": {
        "foreground": "#00D1FF"
      }
    },
    {
      "name": "Function, Special Method",
      "scope": [
        "entity.name.function",
        "meta.function-call",
        "variable.function",
        "support.function",
        "keyword.other.special-method"
      ],
      "settings": {
        "foreground": "#00D1FF"
      }
    },
    {
      "name": "Block Level Variables",
      "scope": [
        "meta.block variable.other"
      ],
      "settings": {
        "foreground": "#F8F9FA"
      }
    },
    {
      "name": "Other Variable, String Link",
      "scope": [
        "support.other.variable",
        "string.other.link"
      ],
      "settings": {
        "foreground": "#F8F9FA"
      }
    },
    {
      "name": "Number, Constant, Function Argument, Tag Attribute, Embedded",
      "scope": [
        "constant.numeric",
        "constant.language",
        "support.constant",
        "constant.character",
        "constant.escape",
        "variable.parameter",
        "keyword.other.unit",
        "keyword.other"
      ],
      "settings": {
        "foreground": "#00D1FF"
      }
    },
    {
      "name": "String, Symbols, Inherited Class, Markup Heading",
      "scope": [
        "string",
        "constant.other.symbol",
        "constant.other.key",
        "entity.other.inherited-class",
        "markup.heading",
        "markup.inserted.git_gutter",
        "meta.group.braces.curly constant.other.object.key.js string.unquoted.label.js"
      ],
      "settings": {
        "foreground": "#00D1FF"
      }
    },
    {
      "name": "Class, Support",
      "scope": [
        "entity.name",
        "support.type",
        "support.class",
        "support.other.namespace.use.php",
        "meta.use.php",
        "support.other.namespace.php",
        "markup.changed.git_gutter",
        "support.type.sys-types"
      ],
      "settings": {
        "foreground": "#00D1FF"
      }
    },
    {
      "name": "Entity Types",
      "scope": [
        "support.type"
      ],
      "settings": {
        "foreground": "#B266FF"
      }
    },
    {
      "name": "CSS Class and Support",
      "scope": [
        "source.css support.type.property-name",
        "source.sass support.type.property-name",
        "source.scss support.type.property-name",
        "source.less support.type.property-name",
        "source.stylus support.type.property-name",
        "source.postcss support.type.property-name"
      ],
      "settings": {
        "foreground": "#00D1FF"
      }
    },
    {
      "name": "Sub-methods",
      "scope": [
        "entity.name.module.js",
        "variable.import.parameter.js",
        "variable.other.class.js"
      ],
      "settings": {
        "foreground": "#F8F9FA"
      }
    },
    {
      "name": "Language methods",
      "scope": [
        "variable.language"
      ],
      "settings": {
        "fontStyle": "italic",
        "foreground": "#B266FF"
      }
    },
    {
      "name": "entity.name.method.js",
      "scope": [
        "entity.name.method.js"
      ],
      "settings": {
        "fontStyle": "italic",
        "foreground": "#00D1FF"
      }
    },
    {
      "name": "meta.method.js",
      "scope": [
        "meta.class-method.js entity.name.function.js",
        "variable.function.constructor"
      ],
      "settings": {
        "foreground": "#00D1FF"
      }
    },
    {
      "name": "Attributes",
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#B266FF"
      }
    },
    {
      "name": "HTML Attributes",
      "scope": [
        "text.html.basic entity.other.attribute-name.html",
        "text.html.basic entity.other.attribute-name"
      ],
      "settings": {
        "fontStyle": "italic",
        "foreground": "#00D1FF"
      }
    },
    {
      "name": "CSS Classes",
      "scope": [
        "entity.other.attribute-name.class"
      ],
      "settings": {
        "foreground": "#00D1FF"
      }
    },
    {
      "name": "CSS ID's",
      "scope": [
        "source.sass keyword.control"
      ],
      "settings": {
        "foreground": "#00D1FF"
      }
    },
    {
      "name": "Inserted",
      "scope": [
        "markup.inserted"
      ],
      "settings": {
        "foreground": "#00D1FF"
      }
    },
    {
      "name": "Deleted",
      "scope": [
        "markup.deleted"
      ],
      "settings": {
        "foreground": "#B266FF"
      }
    },
    {
      "name": "Changed",
      "scope": [
        "markup.changed"
      ],
      "settings": {
        "foreground": "#B266FF"
      }
    },
    {
      "name": "Regular Expressions",
      "scope": [
        "string.regexp"
      ],
      "settings": {
        "foreground": "#00D1FF"
      }
    },
    {
      "name": "Escape Characters",
      "scope": [
        "constant.character.escape"
      ],
      "settings": {
        "foreground": "#00D1FF"
      }
    },
    {
      "name": "URL",
      "scope": [
        "*url*",
        "*link*",
        "*uri*"
      ],
      "settings": {
        "fontStyle": "underline"
      }
    },
    {
      "name": "Decorators",
      "scope": [
        "tag.decorator.js entity.name.tag.js",
        "tag.decorator.js punctuation.definition.tag.js"
      ],
      "settings": {
        "fontStyle": "italic",
        "foreground": "#00D1FF"
      }
    },
    {
      "name": "ES7 Bind Operator",
      "scope": [
        "source.js constant.other.object.key.js string.unquoted.label.js"
      ],
      "settings": {
        "fontStyle": "italic",
        "foreground": "#B266FF"
      }
    },
    {
      "name": "JSON Key - Level 0",
      "scope": [
        "source.json meta.structure.dictionary.json support.type.property-name.json"
      ],
      "settings": {
        "foreground": "#00D1FF"
      }
    },
    {
      "name": "JSON Key - Level 1",
      "scope": [
        "source.json meta.structure.dictionary.json meta.structure.dictionary.value.json meta.structure.dictionary.json support.type.property-name.json"
      ],
      "settings": {
        "foreground": "#B266FF"
      }
    },
    {
      "name": "JSON Key - Level 2",
      "scope": [
        "source.json meta.structure.dictionary.json meta.structure.dictionary.value.json meta.structure.dictionary.json meta.structure.dictionary.value.json meta.structure.dictionary.json support.type.property-name.json"
      ],
      "settings": {
        "foreground": "#F8F9FA"
      }
    },
    {
      "name": "Markdown - Plain",
      "scope": [
        "text.html.markdown",
        "punctuation.definition.list_item.markdown"
      ],
      "settings": {
        "foreground": "#F8F9FA"
      }
    },
    {
      "name": "Markdown - Markup Raw Inline",
      "scope": [
        "text.html.markdown markup.inline.raw.markdown"
      ],
      "settings": {
        "foreground": "#B266FF"
      }
    },
    {
      "name": "Markdown - Markup Raw Inline Punctuation",
      "scope": [
        "text.html.markdown markup.inline.raw.markdown punctuation.definition.raw.markdown"
      ],
      "settings": {
        "foreground": "#00D1FF"
      }
    },
    {
      "name": "Markdown - Heading",
      "scope": [
        "markdown.heading",
        "markup.heading | markup.heading entity.name",
        "markup.heading.markdown punctuation.definition.heading.markdown"
      ],
      "settings": {
        "foreground": "#00D1FF"
      }
    },
    {
      "name": "Markup - Italic",
      "scope": [
        "markup.italic"
      ],
      "settings": {
        "fontStyle": "italic",
        "foreground": "#B266FF"
      }
    },
    {
      "name": "Markup - Bold",
      "scope": [
        "markup.bold",
        "markup.bold string"
      ],
      "settings": {
        "fontStyle": "bold",
        "foreground": "#B266FF"
      }
    },
    {
      "name": "Markup - Bold-Italic",
      "scope": [
        "markup.bold markup.italic",
        "markup.italic markup.bold",
        "markup.quote markup.bold",
        "markup.bold markup.italic string",
        "markup.italic markup.bold string",
        "markup.quote markup.bold string"
      ],
      "settings": {
        "fontStyle": "bold italic",
        "foreground": "#B266FF"
      }
    },
    {
      "name": "Markup - Underline",
      "scope": [
        "markup.underline"
      ],
      "settings": {
        "fontStyle": "underline",
        "foreground": "#00D1FF"
      }
    },
    {
      "name": "Markdown - Blockquote",
      "scope": [
        "markup.quote punctuation.definition.blockquote.markdown"
      ],
      "settings": {
        "foreground": "#00D1FF"
      }
    },
    {
      "name": "Markup - Quote",
      "scope": [
        "markup.quote"
      ],
      "settings": {
        "fontStyle": "italic",
        "foreground": "#B266FF"
      }
    },
    {
      "name": "Markdown - Link",
      "scope": [
        "string.other.link.title.markdown"
      ],
      "settings": {
        "foreground": "#00D1FF"
      }
    },
    {
      "name": "Markdown - Link Description",
      "scope": [
        "string.other.link.description.title.markdown"
      ],
      "settings": {
        "foreground": "#B266FF"
      }
    },
    {
      "name": "Markdown - Link Anchor",
      "scope": [
        "constant.other.reference.link.markdown"
      ],
      "settings": {
        "foreground": "#00D1FF"
      }
    },
    {
      "name": "Markup - Raw Block",
      "scope": [
        "markup.raw.block"
      ],
      "settings": {
        "foreground": "#B266FF"
      }
    }
  ]
}