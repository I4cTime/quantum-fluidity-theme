{
  "name": "Quantum Fluidity Light",
  "type": "light",
  "semanticHighlighting": true,
  "semanticTokenColors": {
    "class": {
      "foreground": "#00B359",
      "bold": true
    },
    "interface": {
      "foreground": "#D99900",
      "italic": true
    },
    "function": {
      "foreground": "#0066CC",
      "italic": true
    },
    "method": {
      "foreground": "#0066CC",
      "italic": true
    },
    "variable.readonly": {
      "foreground": "#050505",
      "bold": true
    },
    "variable.defaultLibrary": {
      "foreground": "#0099CC",
      "bold": true
    },
    "property": {
      "foreground": "#050505"
    },
    "parameter": {
      "foreground": "#0099CC",
      "italic": true
    },
    "enum": {
      "foreground": "#00B359",
      "bold": true
    },
    "enumMember": {
      "foreground": "#D99900"
    },
    "type": {
      "foreground": "#00B359"
    },
    "typeParameter": {
      "foreground": "#00B359",
      "italic": true
    },
    "struct": {
      "foreground": "#00B359",
      "bold": true
    },
    "namespace": {
      "foreground": "#050505"
    },
    "decorator": {
      "foreground": "#0066CC",
      "italic": true
    },
    "macro": {
      "foreground": "#9933FF"
    },
    "event": {
      "foreground": "#D99900"
    },
    "property.readonly": {
      "foreground": "#050505",
      "bold": true
    },
    "*.deprecated": {
      "strikethrough": true
    }
  },
