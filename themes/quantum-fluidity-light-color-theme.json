{
  "name": "Quantum Fluidity Light",
  "type": "light",
  "semanticHighlighting": true,
  "semanticTokenColors": {
    "class": {
      "foreground": "#00B359",
      "bold": true
    },
    "interface": {
      "foreground": "#D99900",
      "italic": true
    },
    "function": {
      "foreground": "#0066CC",
      "italic": true
    },
    "method": {
      "foreground": "#0066CC",
      "italic": true
    },
    "variable.readonly": {
      "foreground": "#050505",
      "bold": true
    },
    "variable.defaultLibrary": {
      "foreground": "#0099CC",
      "bold": true
    },
    "property": {
      "foreground": "#050505"
    },
    "parameter": {
      "foreground": "#0099CC",
      "italic": true
    }
  },
  "colors": {
    "editor.background": "#F8F9FA",
    "editor.foreground": "#050505",
    "activityBar.background": "#F8F9FA",
    "activityBar.foreground": "#050505",
    "activityBar.inactiveForeground": "#05050580",
    "activityBarBadge.background": "#B266FF",
    "activityBarBadge.foreground": "#F8F9FA",
    "activityBar.border": "#E5E7EB",
    "sideBar.background": "#F8F9FA",
    "sideBar.foreground": "#050505",
    "sideBar.border": "#E5E7EB",
    "sideBarSectionHeader.background": "#E5E7EB",
    "sideBarSectionHeader.foreground": "#050505",
    "terminal.background": "#F8F9FA",
    "terminal.foreground": "#050505",
    "terminalCursor.foreground": "#0099CC",
    "terminal.ansiBlack": "#050505",
    "terminal.ansiRed": "#CC0044",
    "terminal.ansiGreen": "#00B359",
    "terminal.ansiYellow": "#D99900",
    "terminal.ansiBlue": "#0099CC",
    "terminal.ansiMagenta": "#9933FF",
    "terminal.ansiCyan": "#0099CC",
    "terminal.ansiWhite": "#F8F9FA",
    "terminal.ansiBrightBlack": "#1A1A2E",
    "terminal.ansiBrightRed": "#FF0055",
    "terminal.ansiBrightGreen": "#00E676",
    "terminal.ansiBrightYellow": "#FFB800",
    "terminal.ansiBrightBlue": "#00D1FF",
    "terminal.ansiBrightMagenta": "#B266FF",
    "terminal.ansiBrightCyan": "#00D1FF",
    "terminal.ansiBrightWhite": "#FFFFFF",
    "editor.selectionBackground": "#E5E7EB",
    "editor.selectionHighlightBackground": "#E5E7EB80",
    "editor.wordHighlightBackground": "#E5E7EB80",
    "editor.lineHighlightBackground": "#F0F2F5",
    "editorLineNumber.foreground": "#05050540",
    "editorLineNumber.activeForeground": "#0099CC",
    "editorCursor.foreground": "#0099CC",
    "editorIndentGuide.background": "#E5E7EB80",
    "editorIndentGuide.activeBackground": "#D1D5DB",
    "list.activeSelectionBackground": "#E5E7EB",
    "list.activeSelectionForeground": "#050505",
    "list.inactiveSelectionBackground": "#E5E7EB80",
    "list.inactiveSelectionForeground": "#050505",
    "list.hoverBackground": "#F0F2F5",
    "list.hoverForeground": "#050505",
    "list.focusBackground": "#E5E7EB",
    "list.focusForeground": "#0099CC",
    "list.highlightForeground": "#0099CC",
    "focusBorder": "#0099CC",
    "badge.background": "#B266FF",
    "badge.foreground": "#F8F9FA",
    "panel.background": "#F8F9FA",
    "panel.border": "#E5E7EB",
    "panelTitle.activeBorder": "#0099CC",
    "panelTitle.activeForeground": "#050505",
    "panelTitle.inactiveForeground": "#05050580",
    "tab.activeBackground": "#F8F9FA",
    "tab.activeForeground": "#050505",
    "tab.activeBorderTop": "#0099CC",
    "tab.activeBorder": "#0099CC00",
    "tab.inactiveBackground": "#F0F2F5",
    "tab.inactiveForeground": "#05050580",
    "tab.border": "#E5E7EB",
    "editorGroupHeader.tabsBackground": "#F8F9FA",
    "editorGroup.border": "#E5E7EB",
    "titleBar.activeBackground": "#F8F9FA",
    "titleBar.activeForeground": "#050505",
    "titleBar.inactiveBackground": "#F8F9FA",
    "titleBar.inactiveForeground": "#05050580",
    "statusBar.background": "#E5E7EB",
    "statusBar.foreground": "#050505",
    "statusBar.border": "#E5E7EB",
    "statusBar.debuggingBackground": "#B266FF",
    "statusBar.debuggingForeground": "#F8F9FA",
    "statusBar.noFolderBackground": "#F8F9FA",
    "button.background": "#B266FF",
    "button.foreground": "#F8F9FA",
    "button.hoverBackground": "#9933FF",
    "button.secondaryBackground": "#E5E7EB",
    "button.secondaryForeground": "#050505",
    "button.secondaryHoverBackground": "#D1D5DB",
    "input.background": "#FFFFFF",
    "input.foreground": "#050505",
    "input.border": "#E5E7EB",
    "inputOption.activeBorder": "#0099CC",
    "inputValidation.errorBackground": "#FF005520",
    "inputValidation.errorBorder": "#CC0044",
    "dropdown.background": "#FFFFFF",
    "dropdown.foreground": "#050505",
    "dropdown.border": "#E5E7EB",
    "editorWidget.background": "#FFFFFF",
    "editorWidget.border": "#E5E7EB",
    "editorSuggestWidget.background": "#FFFFFF",
    "editorSuggestWidget.border": "#E5E7EB",
    "editorSuggestWidget.selectedBackground": "#E5E7EB",
    "diffEditor.insertedTextBackground": "#00B35920",
    "diffEditor.removedTextBackground": "#CC004420",
    "editorGutter.addedBackground": "#00B359",
    "editorGutter.modifiedBackground": "#0099CC",
    "editorGutter.deletedBackground": "#CC0044",
    "scrollbarSlider.background": "#E5E7EB80",
    "scrollbarSlider.hoverBackground": "#D1D5DB",
    "scrollbarSlider.activeBackground": "#0099CC80",
    "scrollbar.shadow": "#E5E7EB",
    "editorBracketHighlight.foreground1": "#0099CC",
    "editorBracketHighlight.foreground2": "#0066CC",
    "editorBracketHighlight.foreground3": "#6633CC",
    "editorBracketHighlight.foreground4": "#9933FF",
    "editorBracketHighlight.foreground5": "#9933FF",
    "editorBracketHighlight.foreground6": "#9933FF",
    "editorBracketHighlight.unexpectedBracket.foreground": "#CC0044",
    "editorOverviewRuler.border": "#E5E7EB",
    "editorOverviewRuler.findMatchForeground": "#0099CC80",
    "editorOverviewRuler.errorForeground": "#CC0044",
    "editorOverviewRuler.warningForeground": "#D99900",
    "editorOverviewRuler.infoForeground": "#0099CC",
    "editorOverviewRuler.bracketMatchForeground": "#9933FF",
    "minimap.findMatchHighlight": "#0099CC",
    "minimap.selectionHighlight": "#E5E7EB",
    "minimap.errorHighlight": "#CC0044",
    "minimap.warningHighlight": "#D99900",
    "minimapGutter.addedBackground": "#00B359",
    "minimapGutter.modifiedBackground": "#0099CC",
    "minimapGutter.deletedBackground": "#CC0044"
  },
  "tokenColors": [
    {
      "name": "Comment",
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "fontStyle": "italic",
        "foreground": "#6B7280"
      }
    },
    {
      "name": "Variables",
      "scope": [
        "variable",
        "string constant.other.placeholder"
      ],
      "settings": {
        "foreground": "#050505"
      }
    },
    {
      "name": "Colors",
      "scope": [
        "constant.other.color"
      ],
      "settings": {
        "foreground": "#0099CC"
      }
    },
    {
      "name": "Invalid",
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "settings": {
        "foreground": "#CC0044"
      }
    },
    {
      "name": "Keyword, Storage",
      "scope": [
        "keyword",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#9933FF",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Operator, Misc",
      "scope": [
        "keyword.control",
        "constant.other.color",
        "punctuation",
        "meta.tag",
        "punctuation.definition.tag",
        "punctuation.separator.inheritance.php",
        "punctuation.definition.tag.html",
        "punctuation.definition.tag.begin.html",
        "punctuation.definition.tag.end.html",
        "punctuation.section.embedded",
        "keyword.other.template",
        "keyword.other.substitution"
      ],
      "settings": {
        "foreground": "#9933FF"
      }
    },
    {
      "name": "Tag",
      "scope": [
        "entity.name.tag",
        "meta.tag.sgml",
        "markup.deleted.git_gutter"
      ],
      "settings": {
        "foreground": "#CC0044"
      }
    },
    {
      "name": "Function, Special Method",
      "scope": [
        "entity.name.function",
        "meta.function-call",
        "variable.function",
        "support.function",
        "keyword.other.special-method"
      ],
      "settings": {
        "foreground": "#0066CC"
      }
    },
    {
      "name": "Block Level Variables",
      "scope": [
        "meta.block variable.other"
      ],
      "settings": {
        "foreground": "#050505"
      }
    },
    {
      "name": "Other Variable, String Link",
      "scope": [
        "support.other.variable",
        "string.other.link"
      ],
      "settings": {
        "foreground": "#050505"
      }
    },
    {
      "name": "Number, Constant, Function Argument, Tag Attribute, Embedded",
      "scope": [
        "constant.numeric",
        "constant.language",
        "support.constant",
        "constant.character",
        "constant.escape",
        "variable.parameter",
        "keyword.other.unit",
        "keyword.other"
      ],
      "settings": {
        "foreground": "#D99900"
      }
    },
    {
      "name": "String, Symbols, Inherited Class, Markup Heading",
      "scope": [
        "string",
        "constant.other.symbol",
        "constant.other.key",
        "entity.other.inherited-class",
        "markup.heading",
        "markup.inserted.git_gutter",
        "meta.group.braces.curly constant.other.object.key.js string.unquoted.label.js"
      ],
      "settings": {
        "foreground": "#CC0044"
      }
    },
    {
      "name": "Class, Support",
      "scope": [
        "entity.name",
        "support.type",
        "support.class",
        "support.other.namespace.use.php",
        "meta.use.php",
        "support.other.namespace.php",
        "markup.changed.git_gutter",
        "support.type.sys-types"
      ],
      "settings": {
        "foreground": "#00B359",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Entity Types",
      "scope": [
        "support.type"
      ],
      "settings": {
        "foreground": "#9933FF"
      }
    },
    {
      "name": "CSS Class and Support",
      "scope": [
        "source.css support.type.property-name",
        "source.sass support.type.property-name",
        "source.scss support.type.property-name",
        "source.less support.type.property-name",
        "source.stylus support.type.property-name",
        "source.postcss support.type.property-name"
      ],
      "settings": {
        "foreground": "#0099CC"
      }
    },
    {
      "name": "Sub-methods",
      "scope": [
        "entity.name.module.js",
        "variable.import.parameter.js",
        "variable.other.class.js"
      ],
      "settings": {
        "foreground": "#050505"
      }
    },
    {
      "name": "Language methods",
      "scope": [
        "variable.language"
      ],
      "settings": {
        "fontStyle": "italic",
        "foreground": "#9933FF"
      }
    },
    {
      "name": "entity.name.method.js",
      "scope": [
        "entity.name.method.js"
      ],
      "settings": {
        "fontStyle": "italic",
        "foreground": "#0066CC"
      }
    },
    {
      "name": "meta.method.js",
      "scope": [
        "meta.class-method.js entity.name.function.js",
        "variable.function.constructor"
      ],
      "settings": {
        "foreground": "#0066CC"
      }
    },
    {
      "name": "Attributes",
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#9933FF"
      }
    },
    {
      "name": "HTML Attributes",
      "scope": [
        "text.html.basic entity.other.attribute-name.html",
        "text.html.basic entity.other.attribute-name"
      ],
      "settings": {
        "fontStyle": "italic",
        "foreground": "#CC0044"
      }
    },
    {
      "name": "CSS Classes",
      "scope": [
        "entity.other.attribute-name.class"
      ],
      "settings": {
        "foreground": "#0099CC"
      }
    },
    {
      "name": "CSS ID's",
      "scope": [
        "source.sass keyword.control"
      ],
      "settings": {
        "foreground": "#0099CC"
      }
    },
    {
      "name": "Inserted",
      "scope": [
        "markup.inserted"
      ],
      "settings": {
        "foreground": "#00B359"
      }
    },
    {
      "name": "Deleted",
      "scope": [
        "markup.deleted"
      ],
      "settings": {
        "foreground": "#CC0044"
      }
    },
    {
      "name": "Changed",
      "scope": [
        "markup.changed"
      ],
      "settings": {
        "foreground": "#D99900"
      }
    },
    {
      "name": "Regular Expressions",
      "scope": [
        "string.regexp"
      ],
      "settings": {
        "foreground": "#0099CC"
      }
    },
    {
      "name": "Escape Characters",
      "scope": [
        "constant.character.escape"
      ],
      "settings": {
        "foreground": "#0099CC"
      }
    },
    {
      "name": "URL",
      "scope": [
        "*url*",
        "*link*",
        "*uri*"
      ],
      "settings": {
        "fontStyle": "underline"
      }
    },
    {
      "name": "Decorators",
      "scope": [
        "tag.decorator.js entity.name.tag.js",
        "tag.decorator.js punctuation.definition.tag.js"
      ],
      "settings": {
        "fontStyle": "italic",
        "foreground": "#0099CC"
      }
    },
    {
      "name": "ES7 Bind Operator",
      "scope": [
        "source.js constant.other.object.key.js string.unquoted.label.js"
      ],
      "settings": {
        "fontStyle": "italic",
        "foreground": "#9933FF"
      }
    },
    {
      "name": "JSON Key - Level 0",
      "scope": [
        "source.json meta.structure.dictionary.json support.type.property-name.json"
      ],
      "settings": {
        "foreground": "#0099CC"
      }
    },
    {
      "name": "JSON Key - Level 1",
      "scope": [
        "source.json meta.structure.dictionary.json meta.structure.dictionary.value.json meta.structure.dictionary.json support.type.property-name.json"
      ],
      "settings": {
        "foreground": "#9933FF"
      }
    },
    {
      "name": "JSON Key - Level 2",
      "scope": [
        "source.json meta.structure.dictionary.json meta.structure.dictionary.value.json meta.structure.dictionary.json meta.structure.dictionary.value.json meta.structure.dictionary.json support.type.property-name.json"
      ],
      "settings": {
        "foreground": "#050505"
      }
    },
    {
      "name": "Markdown - Plain",
      "scope": [
        "text.html.markdown",
        "punctuation.definition.list_item.markdown"
      ],
      "settings": {
        "foreground": "#050505"
      }
    },
    {
      "name": "Markdown - Markup Raw Inline",
      "scope": [
        "text.html.markdown markup.inline.raw.markdown"
      ],
      "settings": {
        "foreground": "#9933FF"
      }
    },
    {
      "name": "Markdown - Markup Raw Inline Punctuation",
      "scope": [
        "text.html.markdown markup.inline.raw.markdown punctuation.definition.raw.markdown"
      ],
      "settings": {
        "foreground": "#0099CC"
      }
    },
    {
      "name": "Markdown - Heading",
      "scope": [
        "markdown.heading",
        "markup.heading | markup.heading entity.name",
        "markup.heading.markdown punctuation.definition.heading.markdown"
      ],
      "settings": {
        "foreground": "#0099CC"
      }
    },
    {
      "name": "Markup - Italic",
      "scope": [
        "markup.italic"
      ],
      "settings": {
        "fontStyle": "italic",
        "foreground": "#9933FF"
      }
    },
    {
      "name": "Markup - Bold",
      "scope": [
        "markup.bold",
        "markup.bold string"
      ],
      "settings": {
        "fontStyle": "bold",
        "foreground": "#9933FF"
      }
    },
    {
      "name": "Markup - Bold-Italic",
      "scope": [
        "markup.bold markup.italic",
        "markup.italic markup.bold",
        "markup.quote markup.bold",
        "markup.bold markup.italic string",
        "markup.italic markup.bold string",
        "markup.quote markup.bold string"
      ],
      "settings": {
        "fontStyle": "bold italic",
        "foreground": "#9933FF"
      }
    },
    {
      "name": "Markup - Underline",
      "scope": [
        "markup.underline"
      ],
      "settings": {
        "fontStyle": "underline",
        "foreground": "#0099CC"
      }
    },
    {
      "name": "Markdown - Blockquote",
      "scope": [
        "markup.quote punctuation.definition.blockquote.markdown"
      ],
      "settings": {
        "foreground": "#0099CC"
      }
    },
    {
      "name": "Markup - Quote",
      "scope": [
        "markup.quote"
      ],
      "settings": {
        "fontStyle": "italic",
        "foreground": "#9933FF"
      }
    },
    {
      "name": "Markdown - Link",
      "scope": [
        "string.other.link.title.markdown"
      ],
      "settings": {
        "foreground": "#0099CC"
      }
    },
    {
      "name": "Markdown - Link Description",
      "scope": [
        "string.other.link.description.title.markdown"
      ],
      "settings": {
        "foreground": "#9933FF"
      }
    },
    {
      "name": "Markdown - Link Anchor",
      "scope": [
        "constant.other.reference.link.markdown"
      ],
      "settings": {
        "foreground": "#0099CC"
      }
    },
    {
      "name": "Markup - Raw Block",
      "scope": [
        "markup.raw.block"
      ],
      "settings": {
        "foreground": "#9933FF"
      }
    }
  ]
}